@page
@model Web.Pages.Vehiculos.AgregarModel
@{
}
<h1>Agregar Vehiculo</h1>

<div class="container">
    <div class="col-xl-5 col-lg-6 col-md-8 col-sm-10 mx-auto">
        <form method="post">
            <div class="form-group" >
                <label for="marcas">Marca</label>
                <select asp-for="marcaSeleccionada" class="form-select" asp-items="Model.marcas" id="marcas" onchange="fectModelos()">
                    <option value="" default hidden>Selecciona una marca</option>
                </select>
            </div>
            <div class="form-group">
                <label for="modelos">Modelo</label>
                <select asp-for="vehiculo.IdModelo" class="form-select" asp-items="Model.modelos" id="modelos">
                    <option value="" default hidden>Selecciona una marca</option>
                </select>
            </div>
            <div class="form-group">
                <label class="control-label" asp-for="vehiculo.Placa"></label>
                <input class="form-control" asp-for="vehiculo.Placa" />
                <span class="text-danger" asp-validation-for="vehiculo.Placa" />
            </div>
            <div class="form-group">
                <label class="control-label" asp-for="vehiculo.Precio"></label>
                <input class="form-control" asp-for="vehiculo.Precio" />
                <span class="text-danger" asp-validation-for="vehiculo.Precio" />
            </div>
            <div class="form-group">
                <label class="control-label" asp-for="vehiculo.Annio"></label>
                <input class="form-control" asp-for="vehiculo.Annio" />
                <span class="text-danger" asp-validation-for="vehiculo.Annio" />
            </div>
            <div class="form-group">
                <label class="control-label" asp-for="vehiculo.Color"></label>
                <input class="form-control" asp-for="vehiculo.Color" />
                <span class="text-danger" asp-validation-for="vehiculo.Color" />
            </div>
            <div class="form-group">
                <label class="control-label" asp-for="vehiculo.CorreoPropietario"></label>
                <input class="form-control" asp-for="vehiculo.CorreoPropietario" />
                <span class="text-danger" asp-validation-for="vehiculo.CorreoPropietario" />
            </div>
            <div class="form-group">
                <label class="control-label" asp-for="vehiculo.TelefonoPropietario"></label>
                <input class="form-control" asp-for="vehiculo.TelefonoPropietario" />
                <span class="text-danger" asp-validation-for="vehiculo.TelefonoPropietario" />
            </div>
            <div class="button-group">
                <a class="btn btn-primary" asp-page="./Index">Regresar</a>
                <input type="submit" value="Agregar" class="btn btn-success" />
            </div>
        </form>
    </div>
</div>

@section Scripts{
    <partial name="_ValidationScriptsPartial" />
    <script>

        async function fectModelos(){
            const idMarca = document.getElementById("marcas").value;
            if(!idMarca){return;}
            try{
                const respuesta = await fetch(`?handler=ObtenerModelos&idMarca=${idMarca}`)
                const modelos = await respuesta.json();
                const modelosSelect = document.getElementById("modelos");
                modelosSelect.innerHTML = '<option value = "" hidden default>Seleccione un modelo</option>'
                modelos.forEach(
                    modelo => {
                        const option = document.createElement("option");
                        option.value = modelo.id;
                        option.text = modelo.nombre;
                        modelosSelect.appendChild(option);
                    }
                );
            }catch(error){
                console.log('Error al obtener modelos', error);
            }
        }


    </script>
}
